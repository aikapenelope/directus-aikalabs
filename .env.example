# Directus — NEXUS Data Layer
# https://docs.directus.io/self-hosted/docker-guide.html

# Admin credentials (change in production)
ADMIN_EMAIL=admin@aikalabs.com
ADMIN_PASSWORD=admin123

# Security key (change in production — use a long random string)
SECRET=nexus-aikalabs-secret-change-me

# PostgreSQL
DB_CLIENT=pg
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=directus_pass

# Public URL
PUBLIC_URL=http://localhost:8055

# CORS
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3001,http://localhost:7777,http://localhost:8055

# WebSockets
WEBSOCKETS_ENABLED=true

# MCP Server — generate a static token in Directus UI:
# User Directory → Your User → Token → Generate → Save
# Then set it here and in ~/.zshrc as DIRECTUS_TOKEN
DIRECTUS_TOKEN=
DIRECTUS_URL=http://localhost:8055
