# Directus — NEXUS Data Layer
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Admin account (created on first startup only)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-password

# Security key for token signing (use a long random string)
SECRET=replace-with-a-long-random-string

# PostgreSQL
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=change-this-db-password

# Public URL
PUBLIC_URL=http://localhost:8055

# MCP Server — generate a static token in Directus UI:
# User Directory → Your User → Token → Generate → Save
# Then add to ~/.zshrc:
#   export DIRECTUS_URL="http://localhost:8055"
#   export DIRECTUS_TOKEN="your-token-here"
